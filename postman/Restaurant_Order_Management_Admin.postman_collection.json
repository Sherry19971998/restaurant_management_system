{
  "info": {
    "name": "Restaurant Order Management - Admin",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Admin workflow API test collection. Only covers endpoints and flows for admin-service (menu, table management, etc). Uses {{baseUrl}} as environment variable."
  },
  "variable": [
    { "key": "baseUrl", "value": "{{baseUrl}}" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Automatically set Authorization header if adminJwtToken is present",
          "if (pm.environment.get('adminJwtToken')) {",
          "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.environment.get('adminJwtToken') });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth (admin-service)",
      "item": [
        {
          "name": "Admin Register",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\",\n  \"roles\": [\"ADMIN\"]\n}" },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 && pm.response.json().token) {",
                  "    pm.environment.set('adminJwtToken', pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Menu Management (admin-service)",
      "item": [
        {
          "name": "Add Menu Item",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Pasta Alfredo\",\n  \"description\": \"Creamy sauce\",\n  \"price\": 13.75,\n  \"available\": true,\n  \"restaurantId\": 1\n}" },
            "url": "{{baseUrl}}/api/menu-items"
          }
        },
          {
            "name": "Get All Menu Items",
            "request": {
              "method": "GET",
              "url": "{{baseUrl}}/api/menu-items"
            }
          },
        {
          "name": "Update Menu Item",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Pasta Alfredo\",\n  \"description\": \"Updated\",\n  \"price\": 15.00,\n  \"available\": true,\n  \"restaurantId\": 1\n}" },
            "url": "{{baseUrl}}/api/menu-items/1"
          }
        },
        {
          "name": "Get Menu Item By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/menu-items/1" }
        }
      ]
    },
    {
      "name": "Table Management (admin-service)",
      "item": [
        {
          "name": "Create Table",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"tableNumber\": 1,\n  \"capacity\": 4,\n  \"status\": \"AVAILABLE\",\n  \"restaurantId\": 1\n}" },
            "url": "{{baseUrl}}/api/tables"
          }
        },
          {
            "name": "Get All Tables",
            "request": {
              "method": "GET",
              "url": "{{baseUrl}}/api/tables"
            }
          },
        {
          "name": "Update Table Status",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"OCCUPIED\"\n}" },
            "url": "{{baseUrl}}/api/tables/1/status"
          }
        },
        {
          "name": "Get Table By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/tables/1" }
        }
      ]
    }
  ]
}
