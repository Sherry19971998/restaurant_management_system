{
  "info": {
    "name": "Restaurant Order Management - Customer",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Customer workflow API test collection. 只包含 customer-service 相关接口和流程。使用 {{baseUrl}} 作为环境变量。"
  },
  "variable": [
    { "key": "baseUrl", "value": "{{baseUrl}}" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Automatically set Authorization header if customerJwtToken is present",
          "if (pm.environment.get('customerJwtToken')) {",
          "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.environment.get('customerJwtToken') });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth (customer-service)",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"testpass\",\n  \"roles\": [\"USER\"]\n}" },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Customer Login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"testpass\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 && pm.response.json().token) {",
                  "    pm.environment.set('customerJwtToken', pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Order Management (customer-service)",
      "item": [
        {
          "name": "Place Order with Items",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"diningTableId\": 2,\n  \"customerId\": 2,\n  \"status\": \"PLACED\",\n  \"items\": [\n    {\n      \"menuItemId\": 2,\n      \"quantity\": 1,\n      \"priceAtOrder\": 8.00,\n      \"note\": \"No dressing\"\n    }\n  ]\n}" },
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "Get Order By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/orders/1" }
        },
          {
            "name": "Get All Orders",
            "request": { "method": "GET", "url": "{{baseUrl}}/api/orders" }
          },
        {
          "name": "Get Customer By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/customers/1" }
        },
        {
          "name": "Get All Tables",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/proxy/tables" }
        },
        {
          "name": "Get All Menu Items",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/proxy/menu-items" }
        }
      ]
    },
    {
      "name": "Reservation Management (customer-service)",
      "item": [
        {
          "name": "Make Reservation",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"reservationTime\": \"2026-02-16T20:00:00\",\n  \"partySize\": 4,\n  \"status\": \"CONFIRMED\",\n  \"diningTableId\": 1,\n  \"customerId\": 2\n}" },
            "url": "{{baseUrl}}/api/reservations"
          }
        },
        {
          "name": "Get Reservation By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/reservations/1" }
        },
        {
          "name": "Get Customer By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/customers/1" }
        },
        {
          "name": "Get All Tables",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/proxy/tables" }
        }
      ]
    },
    {
      "name": "Order Status & Payment (customer-service)",
      "item": [
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"PAID\"\n}" },
            "url": "{{baseUrl}}/api/orders/1/status"
          }
        },
        {
          "name": "Pay Order",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 100.00,\n  \"paymentMethod\": \"CASH\"\n}" },
            "url": "{{baseUrl}}/api/orders/1/pay"
          }
        },
        {
          "name": "Get Order By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/orders/1" }
        }
      ]
    },
    {
      "name": "User Management (customer-service)",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"testpass\",\n  \"roles\": [\"USER\"]\n}" },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jordan Lee\",\n  \"phone\": \"555-3333\",\n  \"email\": \"jordan@example.com\"\n}" },
            "url": "{{baseUrl}}/api/customers"
          }
        },
        {
          "name": "Get Customer By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/customers/1" }
        }
      ]
    }
  ]
}
